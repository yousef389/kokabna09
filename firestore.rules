rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function mainCouple() { return get(/databases/$(database)/documents/couple/main); }
    function isMember() {
      return signedIn()
        && exists(/databases/$(database)/documents/couple/main)
        && request.auth.uid in mainCouple().data.memberUids;
    }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/couple/main)
        && request.auth.uid == mainCouple().data.adminUid;
    }
    function isPartner() {
      return signedIn()
        && exists(/databases/$(database)/documents/couple/main)
        && request.auth.uid == mainCouple().data.partnerUid;
    }
    function onlyTwoMembers(data) {
      return data.memberUids is list && data.memberUids.size() <= 2;
    }
    // الحقول الخاصة بالأدمن فقط — لا يقدر الشريك يعدّلها
    function adminOnlyFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['adminUid','partnerUid','memberUids','inviteCode','inviteCreatedAt']);
    }

    match /couple/main {
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/couple/main)
        && request.resource.data.adminUid == request.auth.uid
        && request.resource.data.memberUids == [request.auth.uid]
        && request.resource.data.partnerUid == null;
      // ✅ كلا المستخدمين يقدروا يقرأوا
      allow read: if isMember();
      // ✅ الأدمن يقدر يعدّل كل شيء | الشريك يقدر يعدّل الثيم والتاريخ فقط
      allow update: if isMember()
        && onlyTwoMembers(request.resource.data)
        && (isAdmin() || !adminOnlyFields());
      allow delete: if false;
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if isMember() && uid in mainCouple().data.memberUids;
      allow update: if isMember() && request.auth.uid == uid || isAdmin();
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, create, update: if isMember();
      allow delete: if isAdmin();
      match /messages/{messageId} {
        allow read: if isMember();
        allow create: if isMember() && request.resource.data.senderId == request.auth.uid;
        allow update: if isMember() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
        allow delete: if isMember() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
      }
    }

    match /{collection}/{docId} {
      allow read: if isMember() && collection in [
        'stories','albums','album_items','notes','files','pages','page_files','calls','notifications','settings','memories','stickers'
      ];
      allow create: if isMember() && collection in [
        'stories','albums','album_items','notes','files','pages','page_files','calls','notifications','settings','memories','stickers'
      ];
      allow update: if isMember() && collection in [
        'stories','albums','album_items','notes','files','pages','page_files','calls','notifications','settings','memories','stickers'
      ];
      allow delete: if isAdmin() && collection in [
        'stories','albums','album_items','notes','files','pages','page_files','calls','notifications','settings','memories','stickers'
      ];
    }
  }
}
